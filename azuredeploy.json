@description('Number of HiveMQ nodes')
param nodeCount int = 2

@description('VM size for HiveMQ nodes')
param vmSize string = 'Basic_A2'

@description('Admin username')
param adminUsername string

@secure()
@description('Admin password')
param adminPassword string

@description('Enable Public IPs for VMs')
param enableVmPublicIp bool = true

@description('Virtual network name')
param vnetName string = 'hivemq-vnet'

@description('Subnet name')
param subnetName string = 'hivemq-subnet'

var location = resourceGroup().location

resource vnet 'Microsoft.Network/virtualNetworks@2023-09-01' = {
  name: vnetName
  location: location
  properties: {
    addressSpace: {
      addressPrefixes: [
        '10.10.0.0/16'
      ]
    }
    subnets: [
      {
        name: subnetName
        properties: {
          addressPrefix: '10.10.1.0/24'
        }
      }
    ]
  }
}

resource publicIps 'Microsoft.Network/publicIPAddresses@2023-09-01' = [for i in range(0, nodeCount): if (enableVmPublicIp) {
  name: 'hivemq-pip-${i}'
  location: location
  sku: {
    name: 'Standard'
  }
  properties: {
    publicIPAllocationMethod: 'Static'
  }
}]

resource nics 'Microsoft.Network/networkInterfaces@2023-09-01' = [for i in range(0, nodeCount): {
  name: 'hivemq-nic-${i}'
  location: location
  properties: {
    ipConfigurations: [
      {
        name: 'ipconfig1'
        properties: {
          subnet: {
            id: vnet.properties.subnets[0].id
          }
          privateIPAllocationMethod: 'Dynamic'
          publicIPAddress: enableVmPublicIp ? {
            id: publicIps[i].id
          } : null
        }
      }
    ]
  }
}]

resource vms 'Microsoft.Compute/virtualMachines@2023-09-01' = [for i in range(0, nodeCount): {
  name: 'hivemq-vm-${i}'
  location: location
  properties: {
    hardwareProfile: {
      vmSize: vmSize
    }
    osProfile: {
      computerName: 'hivemq-${i}'
      adminUsername: adminUsername
      adminPassword: adminPassword
      linuxConfiguration: {
        disablePasswordAuthentication: false
      }
    }
    storageProfile: {
      imageReference: {
        publisher: 'Canonical'
        offer: '0001-com-ubuntu-server-jammy'
        sku: '22_04-lts'
        version: 'latest'
      }
      osDisk: {
        createOption: 'FromImage'
        managedDisk: {
          storageAccountType: 'Premium_LRS'
        }
      }
    }
    networkProfile: {
      networkInterfaces: [
        {
          id: nics[i].id
        }
      ]
    }
  }
}]
